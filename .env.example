# GalaxyVPN — Next.js web app environment
# Copy to .env.local and fill the blanks.

# --- Supabase (from Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://oneezcaqqqaqsjkuaoor.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=        # anon public key (eyJ...)
SUPABASE_SERVICE_ROLE_KEY=            # service_role key (SECRET — server only)

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Tester Worker (set after the worker is deployed on Render) ---
WORKER_TRIGGER_URL=                   # e.g. https://galaxyvpn-worker.onrender.com/trigger-sync
WORKER_TRIGGER_SECRET=                # must match the worker's WORKER_TRIGGER_SECRET
