# GalaxyVPN Tester Worker — environment
SUPABASE_URL=https://oneezcaqqqaqsjkuaoor.supabase.co
SUPABASE_SERVICE_ROLE_KEY=        # service_role key (SECRET — server only)
WORKER_TRIGGER_SECRET=            # shared secret protecting POST /trigger-sync
SYNC_CRON=*/20 * * * *            # how often to auto-sync
GITHUB_TOKEN=                     # optional, raises GitHub API rate limit
PORT=8080

# --- Real testing (xray-knife) — RUN THIS WORKER FROM RUSSIA ---
# A TCP connect only proves reachability; it does NOT prove the proxy passes
# Russia's DPI. xray-knife does a real connection + URL test (Hiddify-grade),
# bundling xray-core + sing-box. Download for your OS:
#   https://github.com/lilendian0x00/xray-knife/releases
# Leave XRAY_KNIFE_PATH empty to fall back to the weaker TCP-only check.
XRAY_KNIFE_PATH=                  # e.g. C:\tools\xray-knife.exe (full path on Windows)
XRAY_KNIFE_CORE=auto              # auto | singbox | xray
XRAY_KNIFE_URL=https://cloudflare.com/cdn-cgi/trace   # real URL-test target
XRAY_KNIFE_MDELAY=5000            # max acceptable delay (ms)

# --- Gemini re-check (REAL availability — fast) ---
# What decides Gemini is each server's EXIT IP country, not mere reachability of
# a Google URL (the old check passed everything). Stage 1 runs ONE fast batched
# `xray-knife http -x csv` over the whole pool and reads each server's real
# egress country (through the tunnel), classifying by Gemini's supported regions.
# Only servers whose country can't be resolved fall through to a precise
# per-config probe (Stage 2) that reads the Gemini API geo-block from the body.
#
# Because the result depends on the server's exit IP (not your connection), you
# can KEEP YOUR VPN ON during the re-check (default). Set =1 to test on the raw
# connection instead (no single VPN chokepoint — slightly more reliable):
GEMINI_RECHECK_VPN_OFF=0
#
# Stage 1 (batched http) speed knobs — higher threads / lower delay = faster:
GEMINI_BATCH_THREADS=80
GEMINI_BATCH_MDELAY_MS=7000
# Countries where Gemini is unavailable (exit-country classification):
GEMINI_BLOCKED_CC=RU,CN,HK,MO,BY,IR,KP,SY,CU
#
# Stage 2 (precise probe) — runs a config as a NO-AUTH SOCKS5 local proxy. The
# default flags are verified on xray-knife v10 (its default inbound otherwise
# demands a random user/pass). Override if your version differs:
#   older builds:  proxy -c {URI} --inbound socks5://127.0.0.1:{PORT}
XRAY_KNIFE_PROXY_ARGS=proxy inbound -c {URI} -I socks://127.0.0.1:{PORT}
GEMINI_PROXY_SCHEME=socks5        # what the inbound opens: socks5 | http
GEMINI_PROBE_CONCURRENCY=12       # parallel precise probes
GEMINI_PROXY_BASE_PORT=21100      # local port range for the throwaway proxies
# Advanced (rarely needed): override the probe target / block phrase.
# GEMINI_PROBE_URL=https://generativelanguage.googleapis.com/v1beta/models?key=AIzaSyA00000000000000000000000000000000000
# GEMINI_BLOCK_SIGNAL=User location is not supported

# Tip: verify on a couple of known configs BEFORE a full run:
#   node --env-file-if-exists=.env scripts/gemini-probe-test.mjs "vless://..."

# --- Tuning ---
MAX_CONFIGS=800                   # max servers tested per run (sampled evenly)
TEST_CONCURRENCY=40               # parallel TCP tests
DRAIN_MS=2000                     # pause after TCP phase before HTTP calls
# NOTE: on Windows dev machines, high concurrency/volume can exhaust sockets and
# break later fetch() calls. If testing locally, lower these (e.g. MAX_CONFIGS=150
# TEST_CONCURRENCY=12 DRAIN_MS=8000). On Render (Linux) the defaults work fine.
