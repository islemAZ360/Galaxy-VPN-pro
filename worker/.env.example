# GalaxyVPN Tester Worker — environment
SUPABASE_URL=https://oneezcaqqqaqsjkuaoor.supabase.co
SUPABASE_SERVICE_ROLE_KEY=        # service_role key (SECRET — server only)
WORKER_TRIGGER_SECRET=            # shared secret protecting POST /trigger-sync
SYNC_CRON=*/20 * * * *            # how often to auto-sync
GITHUB_TOKEN=                     # optional, raises GitHub API rate limit
PORT=8080

# --- Tuning (defaults are fine on Linux/Render) ---
MAX_CONFIGS=800                   # max servers tested per run (sampled evenly)
TEST_CONCURRENCY=40               # parallel TCP tests
DRAIN_MS=2000                     # pause after TCP phase before HTTP calls
# NOTE: on Windows dev machines, high concurrency/volume can exhaust sockets and
# break later fetch() calls. If testing locally, lower these (e.g. MAX_CONFIGS=150
# TEST_CONCURRENCY=12 DRAIN_MS=8000). On Render (Linux) the defaults work fine.
