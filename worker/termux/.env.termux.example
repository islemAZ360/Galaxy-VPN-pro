# GalaxyVPN Tester Worker — Termux (phone) environment.
# Copy this to the worker root as `.env` and paste your service-role key:
#   cp termux/.env.termux.example .env && nano .env
#
# NEVER commit the real .env — it holds a secret key (.gitignore already blocks it).

SUPABASE_URL=https://oneezcaqqqaqsjkuaoor.supabase.co
SUPABASE_SERVICE_ROLE_KEY=PASTE_YOUR_SERVICE_ROLE_KEY_HERE

# xray-knife: setup.sh installs the binary onto your PATH, so no path is needed.
# (Leave XRAY_KNIFE_PATH unset → defaults to the `xray-knife` command.)
XRAY_KNIFE_CORE=auto
XRAY_KNIFE_URL=https://cloudflare.com/cdn-cgi/trace
XRAY_KNIFE_MDELAY=5000

# Test the whole pool (0 = no cap).
MAX_CONFIGS=0
# Phones have weaker network adapters than a PC — 30 is a safe parallelism.
TEST_CONCURRENCY=30

# Many mobile carriers advertise broken/blocked IPv6; force IPv4 to Supabase.
SUPA_FORCE_IPV4=1
